# === AltiusVista .gitignore ===

# ---Ignore Python files---
__pycache__/
*py[cod]*
*$py.class
venv/
.venv/
.env/

# ---Ignore C and Assembly (Build Artifacts)---
*.o
*.obj
*.so
*.dll
*.dylib
*.exe
*.out
build/
dist/
main_engine_s/

# ---Ignore IDE and Editor Files---
.vscode/
.idea/
.DS_Store
*.log
Thumbs.db
.vs/git 
*instructions.txt
*documentation.txt

# ---Ignore CodeSandbox files---
*save_data.json # For a specific JSON, not just all JSON anymore
.codesandbox/
.devcontainer/